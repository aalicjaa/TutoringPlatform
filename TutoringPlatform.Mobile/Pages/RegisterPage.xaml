<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TutoringPlatform.Mobile.Pages.RegisterPage"
             Title="Rejestracja">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="14">

            <VerticalStackLayout Spacing="4">
                <Label Text="Rejestracja"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="Załóż konto, aby przejść do ofert i rezerwacji"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondary}" />
            </VerticalStackLayout>

            <Border Stroke="{DynamicResource Divider}"
                    StrokeThickness="1"
                    BackgroundColor="{DynamicResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    Padding="16">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Załóż konto"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Imię"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Entry Placeholder="np. Anna"
                               Text="{Binding FirstName}"
                               Style="{DynamicResource FormEntry}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nazwisko"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Entry Placeholder="np. Kowalska"
                               Text="{Binding LastName}"
                               Style="{DynamicResource FormEntry}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Entry Placeholder="np. anna@email.com"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               Style="{DynamicResource FormEntry}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Hasło"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Entry Placeholder="Minimum 6 znaków"
                               IsPassword="True"
                               Text="{Binding Password}"
                               Style="{DynamicResource FormEntry}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Powtórz hasło"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Entry Placeholder="Powtórz hasło"
                               IsPassword="True"
                               Text="{Binding PasswordConfirm}"
                               Style="{DynamicResource FormEntry}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Rejestrujesz się jako"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Picker ItemsSource="{Binding RoleOptions}"
                                SelectedItem="{Binding Role}"
                                Title="Wybierz rolę" />
                    </VerticalStackLayout>

                    <Button Text="Zarejestruj"
                            Command="{Binding RegisterCommand}" />

                    <Button Text="Mam już konto → Zaloguj"
                            Style="{DynamicResource LinkButton}"
                            Command="{Binding GoToLoginCommand}"
                            HorizontalOptions="Center" />

                    <Label Text="{Binding Error}"
                           FontSize="12"
                           TextColor="{DynamicResource Danger}"
                           IsVisible="{Binding Error, Converter={StaticResource StringNotEmptyConverter}}" />

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>