{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=TutoringPlatformDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True"
  },
